# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Simple Password Authentication
# Leave empty to disable authentication
APP_PASSWORD=

# Cron Job Secret (required for securing cron endpoints)
CRON_SECRET=generate-a-random-secret-string

# AI Configuration
# Choose: 'claude' or 'openai'
AI_PROVIDER=claude

# For Claude (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# For OpenAI (alternative)
OPENAI_API_KEY=your-openai-api-key

# Alpha Vantage API Key (backup for stocks)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Exchange Rate API Key (FX rates)
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# App Configuration
GOAL_AMOUNT=15000000000
GOAL_CURRENCY=IDR
